# Example environment variables for Smart Security IoT
ADMIN_USERNAME=admin
# Store a password hash for ADMIN_PASSWORD_HASH (generate with werkzeug.security.generate_password_hash)
ADMIN_PASSWORD_HASH=
RTSP_URL=rtsp://<username>:<password>@<camera-ip>/stream
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password_or_oauth
ALERT_EMAIL_TO=receiver@example.com
# Home Secure Access configuration
CAMERA_SOURCE=rtsp
RTSP_URL=rtsp://username:password@camera.local:554/stream
WEBCAM_INDEX=0
LOGO_HOST=192.168.10.100
LOGO_RACK=0
LOGO_SLOT=1
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=changeme_hash
AES_SECRET=replace_with_secure_random_32_bytes
DATABASE_PATH=database/system.db
APP_ENV=development
