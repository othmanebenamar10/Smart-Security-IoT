{
  "name": "smart-secure-access-iot-system",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Secure Access IoT System - desktop access control with face recognition, Siemens LOGO! V8 and RTSP camera.",
  "main": "dist/main/main.js",
  "author": "Smart Secure Access IoT Team",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start:dev": "npm run build:renderer && npm run build:main && electron .",
    "dev": "concurrently \"npm:watch:renderer\" \"npm:watch:main\" \"npm:start:electron\"",
    "watch:renderer": "vite --config renderer/vite.config.ts",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "start:electron": "wait-on dist/renderer/index.html && electron .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test:main && npm run test:python",
    "test:main": "jest --config jest.config.cjs",
    "test:python": "pytest tests/python",
    "package": "npm run build && electron-builder --win nsis",
    "package:linux": "npm run build && electron-builder --linux deb",
    "package:windows": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@electron/get": "^1.3.5",
    "axios": "^1.7.2",
    "dotenv": "^16.0.3",
    "electron-log": "^4.4.7",
    "framer-motion": "^10.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.7.2",
    "sqlite": "^5.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^26.3.0",
    "electron-builder": "^24.6.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.4",
    "wait-on": "^7.0.1",
    "tailwindcss": "^3.4.4",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19"
  },
  "build": {
    "productName": "Smart Secure Access IoT System",
    "appId": "com.smartsecure.access.iot",
    "files": [
      "dist/**",
      "renderer/dist/**",
      "main/**",
      "preload/**",
      "ai/**",
      "plc/**",
      "database/**",
      "security/**",
      "logs/**",
      "app/**",
      "package.json",
      "README.md"
    ],
    "directories": {
      "buildResources": "installer"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": ["nsis"],
      "publish": null
    },
    "linux": {
      "target": ["deb"],
      "maintainer": "Smart Secure Access IoT Team",
      "category": "Utility"
    }
  }
}
