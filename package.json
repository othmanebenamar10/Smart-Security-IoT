{
  "name": "smart-secure-access-iot-system",
  "version": "0.1.0",
  "private": true,
  "description": "Home secure access system - smart home entry monitoring with face recognition, camera stream and access relay.",
  "main": "electron-main.js",
  "author": "Home Secure Access Team",
  "license": "MIT",
  "scripts": {
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start:dev": "npm run build:renderer && npm run build:main && electron .",
    "dev": "concurrently \"npm:watch:renderer\" \"npm:watch:main\" \"npm:start:electron\"",
    "watch:renderer": "vite build --watch --config vite.config.ts",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "start:electron": "wait-on dist/renderer/index.html && electron .",
    "lint": "npm run typecheck",
    "test": "npm run test:main && npm run test:python",
    "test:main": "jest --config jest.config.cjs",
    "test:python": "node tests/run-python-tests.cjs",
    "python:install": "py -3.10 -m pip install -r ai\\requirements.txt",
    "webcam:enroll": "node scripts\\webcam-enroll.cjs",
    "webcam:test": "node scripts\\webcam-test.cjs",
    "package": "npm run build && electron-builder --win nsis",
    "package:linux": "npm run build && electron-builder --linux deb",
    "package:windows": "npm run build && electron-builder --win nsis"
    ,
    "electron-dev": "concurrently \"py -3.10 -m backend.app\" \"py -3.10 ai\\face_service.py\" \"electron .\""
  },
  "dependencies": {
    "@electron/get": "^1.3.5",
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.0.3",
    "electron-log": "^4.4.7",
    "framer-motion": "^10.18.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.7.2",
    "sqlite": "^5.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^26.3.0",
    "electron-builder": "24.6.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "productName": "Home Secure Access",
    "appId": "com.smartsecure.access.iot",
    "files": [
      "dist/**",
      "main/**",
      "preload/**",
      "ai/**",
      "plc/**",
      "database/**",
      "security/**",
      "logs/**",
      "app/**",
      "package.json",
      "README.md"
    ],
    "directories": {
      "buildResources": "installer"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Home Secure Access",
      "artifactName": "HomeSecureAccess-${version}-Setup.${ext}",
      "installerIcon": "installer/icon.png",
      "uninstallerIcon": "installer/icon.png",
      "installerHeaderIcon": "installer/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publish": null,
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "linux": {
      "target": [
        "deb"
      ],
      "maintainer": "Home Secure Access Team",
      "category": "Utility"
    }
  }
}
