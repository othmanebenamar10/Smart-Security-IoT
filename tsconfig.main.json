{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/main",
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"]
  },
  "include": ["main/**/*.ts", "preload/**/*.ts", "database/**/*.ts", "security/**/*.ts", "logs/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["**/*_improved.ts"]
}
